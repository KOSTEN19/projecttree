MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change_me_strong_password

ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me_strong_admin_password

# Минимум 32 символа, лучше 48+ случайных (пример: openssl rand -base64 48)
JWT_SECRET=replace_with_long_random_secret_at_least_32_chars
# После перезапуска сервера все выданные токены недействительны (один инстанс). Для нескольких реплик: false
JWT_BIND_TO_PROCESS=true
# Срок access-токена (time.ParseDuration), по умолчанию в коде 24h
JWT_ACCESS_TTL=24h

# Опционально: ИИ-факты на главной (OpenAI-совместимый API, например Ollama)
# AI_ENABLED=true
# AI_API_BASE_URL=http://127.0.0.1:11434/v1
# AI_MODEL=llama3.2
# AI_API_KEY=

# --- Локальный ИИ в Docker Compose (сервис ollama) ---
# Образ: по умолчанию в compose — alpine/ollama (компактный CPU). Официальный тяжёлый: OLLAMA_IMAGE=ollama/ollama:latest
# OLLAMA_IMAGE=alpine/ollama:latest
# Модель (легче для диска: tinyllama, qwen2:0.5b): docker compose exec ollama ollama pull tinyllama
# AI_ENABLED=true
# AI_MODEL=tinyllama
# В compose у server уже AI_API_BASE_URL=http://ollama:11434/v1. Вне Docker: http://127.0.0.1:11434/v1
# AI_API_KEY=

